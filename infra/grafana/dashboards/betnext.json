{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["betnext", "lot-11"],
  "title": "BetNext — Monitoring",
  "uid": "betnext-monitoring",
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Paris / min par statut (pic de paris)",
      "description": "Taux de paris placed/won/lost — un pic de paris se voit ici.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ppm" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(betnext_bets_total[1m])) by (status) * 60",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Volume total misé (€)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyEUR" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "sum(betnext_bet_amount_sum)", "legendFormat": "misé" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Utilisateurs connectés (WebSocket)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(betnext_active_users_gauge)", "legendFormat": "actifs" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latence recalcul cotes p95 (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(betnext_odds_calculation_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Limites RG atteintes & erreurs webhook / min",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "ppm" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(betnext_rg_limit_hits_total[5m])) by (limit) * 60",
          "legendFormat": "RG {{limit}}"
        },
        {
          "refId": "B",
          "expr": "sum(rate(betnext_stripe_webhook_errors_total[5m])) * 60",
          "legendFormat": "webhook errors"
        }
      ]
    }
  ]
}
