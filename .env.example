# ─────────────────────────────────────────────────────────────────────────
# BetNext — variables d'environnement (exemple). Copier en `.env` puis adapter.
# Le `.env` réel est gitignored.
# ─────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (compte admin du conteneur) ──
POSTGRES_DB=betnext
POSTGRES_USER=betnext
POSTGRES_PASSWORD=betnext
POSTGRES_PORT=5432

# Mots de passe des 4 users SQL par service (utilisés par le script d'init)
USERS_DB_PASSWORD=users_pwd
BETTING_DB_PASSWORD=betting_pwd
EVENTS_DB_PASSWORD=events_pwd
WALLET_DB_PASSWORD=wallet_pwd

# ── DSN PostgreSQL ──
# DSN admin (migrations, outillage)
DATABASE_URL=postgresql://betnext:betnext@localhost:5432/betnext
# Un DSN par service : chaque user ne voit QUE son schéma
USERS_DATABASE_URL=postgresql://users_svc:users_pwd@localhost:5432/betnext?schema=users
BETTING_DATABASE_URL=postgresql://betting_svc:betting_pwd@localhost:5432/betnext?schema=betting
EVENTS_DATABASE_URL=postgresql://events_svc:events_pwd@localhost:5432/betnext?schema=events
WALLET_DATABASE_URL=postgresql://wallet_svc:wallet_pwd@localhost:5432/betnext?schema=wallet

# ── Redis (cache + BullMQ + Pub/Sub) ──
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ── JWT (cf. ADR-009 : access token court + refresh rotatif) ──
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=5m
JWT_REFRESH_EXPIRY=7d

# ── API Gateway ──
PORT=3000

# ── Stripe (mocké en école — requis seulement pour le provider réel) ──
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── APIs jeux (mockées en école) ──
RIOT_API_KEY=
RIOT_PLATFORM=euw1
RIOT_REGION=europe
LOL_ESPORTS_API_KEY=
