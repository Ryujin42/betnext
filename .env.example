# ─────────────────────────────────────────────────────────────────────────
# BetNext — variables d'environnement (exemple). Copier en `.env` puis adapter.
# Le `.env` réel est gitignored.
# ─────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (compte admin du conteneur) ──
POSTGRES_DB=betnext
POSTGRES_USER=betnext
POSTGRES_PASSWORD=betnext
POSTGRES_PORT=5432

# Mot de passe du user applicatif (utilisé par le script d'init)
APP_DB_PASSWORD=app_pwd

# ── DSN PostgreSQL ──
# Schéma applicatif unique `betnext`, accédé par le user applicatif `betnext_app`
DATABASE_URL=postgresql://betnext_app:app_pwd@localhost:5432/betnext?schema=betnext

# ── Redis (cache + BullMQ + Pub/Sub) ──
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379
# Bus inter-services : `in-memory` (défaut, mono-process) ou `redis` (Lot 7+)
EVENT_BUS_DRIVER=in-memory
# Dashboard BullMQ (api-gateway) — `true` en dev pour l'exposer sous /admin/queues
BULLBOARD_ENABLED=false

# ── JWT (cf. ADR-009 : access token court + refresh rotatif) ──
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=5m
JWT_REFRESH_EXPIRY=7d

# ── API Gateway ──
PORT=3000

# ── User service (Lot 2) ──
USER_SERVICE_PORT=3001
USER_SERVICE_URL=http://localhost:3001

# ── Stripe (mocké en école — requis seulement pour le provider réel) ──
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── APIs jeux (mockées en école) ──
RIOT_API_KEY=
RIOT_PLATFORM=euw1
RIOT_REGION=europe
LOL_ESPORTS_API_KEY=

# ── Event service (Lot 4) ──
EVENT_SERVICE_PORT=3002
EVENT_SERVICE_URL=http://localhost:3002

# ── Betting service (Lot 5) ──
BETTING_SERVICE_PORT=3003
BETTING_SERVICE_URL=http://localhost:3003

# ── Odds engine (Lot 5) ──
ODDS_ENGINE_PORT=3004

# ── Wallet service (Lot 6) ──
WALLET_SERVICE_PORT=3005
WALLET_SERVICE_URL=http://localhost:3005

# ── Notification service (Lot 7 — stub) ──
NOTIFICATION_SERVICE_PORT=3006

# ── Admin SPA (Lot 8) ──
ADMIN_PORT=5174
VITE_GATEWAY_URL=http://localhost:3000
# PSP : `mock` (défaut, contexte scolaire) ou `real` (Stripe, déploiement réel)
PAYMENT_PROVIDER=mock

# ── Jeu responsable — plafonds par défaut (€) tant que Lot 7 (T7.2)
#    ne porte pas les limites par utilisateur ──
RG_DAILY_BET_LIMIT=500
RG_WEEKLY_BET_LIMIT=2000
RG_DAILY_DEPOSIT_LIMIT=1000
RG_WEEKLY_DEPOSIT_LIMIT=5000
