{
  "name": "betnext",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "dev": "nx run-many -t dev",
    "graph": "nx graph",
    "db:migrate": "pnpm --filter @betnext/database db:migrate",
    "db:migrate:revert": "pnpm --filter @betnext/database db:migrate:revert",
    "db:migrate:show": "pnpm --filter @betnext/database db:migrate:show",
    "prepare": "husky",
    "db:seed": "pnpm --filter @betnext/database db:seed"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.17.0",
    "nx": "^22.7.5",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,html}": [
      "prettier --write"
    ]
  }
}
