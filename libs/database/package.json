{
  "name": "@betnext/database",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit",
    "db:migrate": "typeorm-ts-node-commonjs migration:run -d src/data-source.ts",
    "db:migrate:revert": "typeorm-ts-node-commonjs migration:revert -d src/data-source.ts",
    "db:migrate:show": "typeorm-ts-node-commonjs migration:show -d src/data-source.ts"
  },
  "dependencies": {
    "@betnext/shared-types": "workspace:*",
    "@nestjs/typeorm": "^11.0.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
